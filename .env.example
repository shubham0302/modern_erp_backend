# General
NODE_ENV=development

# Gateway
GATEWAY_PORT=4000
SERVICE_NAME=gateway

# JWT
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# Passwords
BCRYPT_ROUNDS=12

# PostgreSQL — shared
# In docker-compose, DB_HOST is overridden to `postgres` per service.
DB_HOST=localhost
DB_PORT=5432
DB_USER=modern_erp
DB_PASSWORD=changeme
DB_NAME=modern_erp_db

# Redis
# In docker-compose, REDIS_HOST is overridden to `redis` per service.
# REDIS_PASSWORD is required; redis-server is launched with --requirepass.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# gRPC service URLs
# In docker-compose: gateway dials `admin-service:5001` / `staff-service:5002`;
# the services themselves bind to `0.0.0.0:<port>` (overridden per service).
ADMIN_SERVICE_URL=localhost:5001
STAFF_SERVICE_URL=localhost:5002

# Rate limiting
RATE_LIMIT_ADMIN=300
RATE_LIMIT_STAFF=200
RATE_LIMIT_WINDOW_SEC=60

# User cache
USER_CACHE_TTL_SEC=600

# Super-admin seed (admin-service, first boot only)
SEED_SUPER_ADMIN_EMAIL=superadmin@modernerp.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME=Super Admin
SEED_SUPER_ADMIN_PHONE=+910000000000

# GlitchTip
GLITCHTIP_DSN=
