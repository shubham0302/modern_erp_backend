{
  "name": "modern-erp-backend",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "nest build",
    "start:admin": "nest start admin --watch",
    "start:staff": "nest start staff --watch",
    "start:inventory": "nest start inventory --watch",
    "start:gateway": "nest start gateway --watch",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs,db}/**/*.ts\" --fix",
    "proto:gen": "./scripts/proto-gen.sh",
    "proto:gen:watch": "chokidar 'proto/**/*.proto' -c 'npm run proto:gen'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "node -r ts-node/register node_modules/typeorm/cli.js",
    "migration:generate": "yarn typeorm migration:generate db/migrations/$npm_config_name -d db/data-source.ts",
    "migration:create": "yarn typeorm migration:create db/migrations/$npm_config_name",
    "migration:run": "yarn typeorm migration:run -d db/data-source.ts",
    "migration:revert": "yarn typeorm migration:revert -d db/data-source.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.8",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.9",
    "@nestjs/microservices": "^10.3.9",
    "@nestjs/platform-express": "^10.3.9",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "@sentry/node": "^7.114.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.33.0",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.9",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.8",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "chokidar-cli": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "supertest": "^7.0.0",
    "testcontainers": "^10.10.4",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-proto": "^1.181.1",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.5.2"
  }
}
