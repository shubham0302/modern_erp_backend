{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "paths": {
      "@modern_erp/common": ["libs/common/src"],
      "@modern_erp/common/*": ["libs/common/src/*"],
      "@modern_erp/logger": ["libs/logger/src"],
      "@modern_erp/logger/*": ["libs/logger/src/*"],
      "@modern_erp/grpc-types": ["libs/grpc-types/src"],
      "@modern_erp/grpc-types/*": ["libs/grpc-types/src/*"]
    }
  }
}
